{
  "name": "capture-spec-sessions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Exports every Warp, Claude Code, or Hermes conversation of one spec across specify/implement/implementation-gate as raw JSONL for a later learning phase.",
  "scripts": {
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "gen:schema": "tsx scripts/gen-schema-lookup.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "protobufjs": "^8.6.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
